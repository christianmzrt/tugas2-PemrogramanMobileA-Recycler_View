<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml - Layout utama aplikasi UNUDHub.
    Struktur:
    - CoordinatorLayout (root): Memungkinkan interaksi antar child (AppBar & FAB)
      ├── AppBarLayout + MaterialToolbar: Header aplikasi sticky
      └── RecyclerView: Daftar mata kuliah scrollable
      └── FloatingActionButton: Tombol aksi melayang (scroll to top)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- AppBar dengan toolbar modern -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D14"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            app:contentInsetStart="0dp">

            <!-- Konten toolbar kustom -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="20dp">

                <!-- Ikon logo kiri -->
                <TextView
                    android:id="@+id/tvToolbarLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓"
                    android:textSize="26sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Nama aplikasi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/toolbar_title"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvToolbarLogo"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Badge jumlah mata kuliah -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/film_count"
                    android:textColor="#00D4FF"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Garis separator bawah toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- RecyclerView: Daftar mata kuliah utama -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="88dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideOverlay"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Floating Action Button: Scroll ke atas -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Scroll to top"
        android:src="@android:drawable/arrow_up_float"
        app:backgroundTint="#00D4FF"
        app:tint="@android:color/black"
        app:elevation="8dp"
        app:rippleColor="#40FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
