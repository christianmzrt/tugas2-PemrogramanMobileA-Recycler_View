<?xml version="1.0" encoding="utf-8"?>
<!--
    item_movie.xml - Layout satu item dalam RecyclerView.
    Setiap item berbentuk Card dengan elemen:
    - Accent bar vertikal kiri (warna unik per film)
    - Emoji icon film
    - Judul, genre, tahun
    - Rating berwarna
    - Deskripsi singkat

    Desain mengikuti prinsip Dark Modern UI:
    - Background card abu gelap (#151520)
    - Corner radius 16dp untuk kesan modern
    - Elevation ringan untuk depth
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#12121C"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1E1E2E"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Accent bar vertikal kiri -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#00D4FF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Container utama konten card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/accentBar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Emoji icon film -->
            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="🎬"
                android:textSize="30sp"
                android:gravity="center"
                android:background="@drawable/emoji_bg1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Judul film -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Movie Title"
                android:textColor="#F1F1F5"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="14dp"
                app:layout_constraintEnd_toStartOf="@id/tvRating"
                app:layout_constraintStart_toEndOf="@id/tvEmoji"
                app:layout_constraintTop_toTopOf="@id/tvEmoji" />

            <!-- Genre film -->
            <TextView
                android:id="@+id/tvGenre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="GENRE"
                android:textColor="#5A5A7A"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginStart="14dp"
                android:layout_marginTop="2dp"
                app:layout_constraintEnd_toStartOf="@id/tvYear"
                app:layout_constraintStart_toEndOf="@id/tvEmoji"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <!-- Rating (warna sesuai accentColor) -->
            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ 8.8"
                android:textColor="#00D4FF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvEmoji" />

            <!-- Tahun rilis -->
            <TextView
                android:id="@+id/tvYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024"
                android:textColor="#3D3D55"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRating" />

            <!-- Garis pemisah tipis -->
            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#1A1A2E"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvEmoji" />

            <!-- Deskripsi singkat film -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Description of the movie goes here with a short synopsis."
                android:textColor="#6B6B8A"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
