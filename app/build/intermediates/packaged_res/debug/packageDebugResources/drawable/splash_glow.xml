<?xml version="1.0" encoding="utf-8"?>
<!--
    splash_glow.xml - Efek cahaya radial di splash screen.
    Membuat ilusi "glow" di tengah layar hitam menggunakan gradient radial.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="150%"
        android:startColor="#1A00D4FF"
        android:centerColor="#0800AACC"
        android:endColor="#000A0A0F" />
</shape>
