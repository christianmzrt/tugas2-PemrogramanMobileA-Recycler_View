<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml - Layout Splash Screen UNUDHub
    Menampilkan logo, nama, tagline aplikasi, dan identitas pengembang.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fitsSystemWindows="true">

    <!-- Background gradient subtle di tengah -->
    <View
        android:id="@+id/glowEffect"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/splash_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Logo emoji besar (Topi Toga) -->
    <TextView
        android:id="@+id/tvSplashLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎓"
        android:textSize="80sp"
        app:layout_constraintBottom_toTopOf="@id/tvSplashTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="24dp" />

    <!-- Nama aplikasi -->
    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:fontFamily="sans-serif-condensed"
        app:layout_constraintBottom_toTopOf="@id/tvSplashSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/toolbar_subtitle"
        android:textColor="#6B7280"
        android:textSize="16sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Garis aksen neon bawah judul -->
    <View
        android:id="@+id/accentLine"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="#00D4FF"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSplashSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Container Identitas Mahasiswa -->
    <LinearLayout
        android:id="@+id/identityContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_name"
            android:textColor="#F1F1F5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_nim"
            android:textColor="#00D4FF"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_class"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="#3D4047"
            android:textSize="10sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
